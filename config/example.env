# ACS Central connection
export ROX_ENDPOINT="https://central.example.com:443"
export ROX_API_TOKEN="your-api-token-here"
# export ROX_INSECURE_SKIP_TLS_VERIFY="true"

# Optional cluster filter (appended to export query)
# export ACS_CLUSTER_NAME="production"

# Export query base (Platform Component workloads)
export ACS_EXPORT_QUERY="Platform Component:true"

# Red Hat Security Data API
export RHSDA_BASE_URL="https://access.redhat.com/hydra/rest/securitydata"
# Product filter fallback (CPE/remote-derived context takes priority)
export RHSDA_PRODUCT_REGEX="OpenShift|RHCOS|Red Hat Enterprise Linux CoreOS"
export RHSDA_TIMEOUT="30"

# Output directory (reports and results)
export OUTPUT_DIR="./data"

# Set to "true" to skip ACS write operations (create/approve exceptions)
export DRY_RUN="false"

# Fetch /v1/images/{id} when export payload lacks scan data or Red Hat labels
export ACS_ENRICH_SCANS="true"
export ACS_ENRICH_LABELS="true"
export ACS_ENRICH_MAX_IMAGES="200"
export ACS_API_TIMEOUT="300"
export ACS_EXPORT_TIMEOUT="900"
export ACS_EXPORT_SERVER_TIMEOUT="600"

# Deferral exception expiry (days from now); used for Fix deferred / Will not fix
export DEFER_EXPIRY_DAYS="90"

# Optional prefix for ACS exception comments (RHSDA evidence appended automatically)
# export EXCEPTION_COMMENT_PREFIX="RHSDA"

# Optional proxy
# export HTTPS_PROXY="http://proxy.example.com:8080"
